# ─── Telegram ────────────────────────────────────────────────────────────────
# Get from @BotFather after running /newbot
BOT_TOKEN=replace_me
BOT_USERNAME=replace_me_bot

# Public HTTPS URL where FastAPI will be reachable (used for NOWPayments IPN)
# e.g. https://your-app.up.railway.app  or  https://your-app.onrender.com
BASE_URL=https://your-domain.example

# ─── Security ─────────────────────────────────────────────────────────────────
# Comma-separated Telegram chat IDs that receive admin alerts (your Telegram numeric ID)
ADMIN_CHAT_IDS=123456789

# Long random secret — run: openssl rand -hex 32
WEBHOOK_SECRET=replace_me_long_random_value
ADMIN_API_KEY=replace_me_long_random_value

# Admin panel login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_me_long_random_password

# Session secret — run: openssl rand -hex 32
SESSION_SECRET=replace_me_long_random_session_secret

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (fine for dev/small installs). Switch to PostgreSQL for production:
# DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname
DATABASE_URL=sqlite+aiosqlite:///./bot.db

# ─── NOWPayments ──────────────────────────────────────────────────────────────
# Get from: https://nowpayments.io/  →  API Keys + IPN settings
NOWPAYMENTS_API_KEY=replace_me
NOWPAYMENTS_IPN_SECRET=replace_me
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1

# Default fiat currency for pricing (used in NOWPayments price_currency)
DEFAULT_CURRENCY=gbp

# Minutes before a payment window expires
ORDER_EXPIRY_MINUTES=90

# ─── Redis (optional for now, required for production FSM) ───────────────────
REDIS_URL=redis://localhost:6379/0

# Set to false during local HTTP testing, true in production (HTTPS only)
SECURE_COOKIES=true
